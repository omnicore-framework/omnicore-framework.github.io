---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const modules = [
  {
    id: '01',
    name: 'Core Framework',
    desc: 'El núcleo operativo del ecosistema.',
  },
  {
    id: '02',
    name: 'AI Engine',
    desc: 'La inteligencia cognitiva del ecosistema.',
  },
  {
    id: '03',
    name: 'Cybersecurity',
    desc: 'La defensa inteligente y preventiva.',
  },
  {
    id: '04',
    name: 'Developer Platform',
    desc: 'Infraestructura avanzada para developers.',
  },
  {
    id: '05',
    name: 'Automation',
    desc: 'La automatización operativa y flujos de trabajo.',
  },
  {
    id: '06',
    name: 'Distributed Systems',
    desc: 'Arquitectura para escala global.',
  },
  {
    id: '07',
    name: 'Observability',
    desc: 'La visión y monitoreo del ecosistema.',
  },
  { id: '08', name: 'Research Lab', desc: 'Innovación y experimentación.' },
  {
    id: '09',
    name: 'System Intelligence',
    desc: 'La conciencia del ecosistema.',
  },
  {
    id: '10',
    name: 'Autonomous Operations',
    desc: 'Operaciones autónomas inteligentes.',
  },
  {
    id: '11',
    name: 'Digital Twin',
    desc: 'La simulación viva del ecosistema.',
  },
  { id: '12', name: 'API & Integration', desc: 'La conectividad universal.' },
  {
    id: '13',
    name: 'Cloud Infrastructure',
    desc: 'Infraestructura moderna nativa en la nube.',
  },
  { id: '14', name: 'Data & Knowledge', desc: 'La memoria a largo plazo.' },
  { id: '15', name: 'Data Science', desc: 'Inteligencia analítica.' },
];
---

<Layout title="Documentation | OmniCore Framework">
  <Header />

  <div
    class="relative mx-auto flex min-h-screen max-w-[1440px] flex-col gap-12 px-6 py-12 md:flex-row md:px-12"
  >
    <!-- Sidebar Navigation -->
    <aside
      class="hidden h-fit w-full flex-shrink-0 overflow-y-auto md:sticky md:top-32 md:block md:w-64"
    >
      <nav class="space-y-8 text-sm">
        <div>
          <h3
            class="mb-4 font-mono text-xs font-bold tracking-widest text-emerald-400 uppercase"
          >
            Introducción
          </h3>
          <ul class="space-y-3 text-white/60">
            <li>
              <a href="#vision" class="transition-colors hover:text-white"
                >Visión General</a>
            </li>
            <li>
              <a href="#filosofia" class="transition-colors hover:text-white"
                >Filosofía del Ecosistema</a>
            </li>
          </ul>
        </div>
        <div>
          <h3
            class="mb-4 font-mono text-xs font-bold tracking-widest text-emerald-400 uppercase"
          >
            Arquitectura
          </h3>
          <ul class="space-y-3 text-white/60">
            <li>
              <a href="#modulos" class="transition-colors hover:text-white"
                >Los 15 Módulos Core</a>
            </li>
            <li>
              <a href="#integracion" class="transition-colors hover:text-white"
                >Patrones de Integración</a>
            </li>
          </ul>
        </div>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="prose prose-invert prose-emerald max-w-3xl flex-1">
      <div class="mb-12 border-b border-white/10 pb-12" id="vision">
        <h1
          class="font-h1 mb-6 text-4xl font-bold tracking-tight text-white md:text-5xl"
        >
          OmniCore Framework
        </h1>
        <p class="mb-8 font-mono text-xl text-emerald-400">
          Ecosistema Inteligente de Infraestructura Nativo para IA
        </p>

        <p class="mb-6 leading-relaxed text-white/80">
          OmniCore Framework no es simplemente un framework tradicional. Es un
          ecosistema modular, inteligente y autónomo diseñado para la
          automatización avanzada, infraestructura moderna, inteligencia
          artificial y ciberseguridad.
        </p>
        <p class="leading-relaxed text-white/80">
          La idea principal es crear una arquitectura donde todas las áreas
          puedan funcionar individualmente, pero también cooperar como un
          sistema unificado e inteligente.
        </p>
      </div>

      <div class="mb-12 border-b border-white/10 pb-12" id="filosofia">
        <h2 class="font-h2 mb-6 text-3xl font-bold text-white">
          Filosofía del Ecosistema
        </h2>
        <blockquote
          class="my-8 rounded-r-lg border-l-4 border-emerald-500 bg-emerald-500/5 py-4 pl-6 text-lg text-white/90 italic"
        >
          "Una capa operativa inteligente para sistemas modernos."
        </blockquote>
        <p class="mb-6 leading-relaxed text-white/80">
          El ecosistema está diseñado bajo los siguientes principios
          fundamentales:
        </p>
        <ul
          class="mb-8 grid grid-cols-2 gap-4 font-mono text-sm text-emerald-400/80"
        >
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> modular-first
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> AI-native
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> security-first
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> cloud-native
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> event-driven
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> autonomous-ready
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> developer-centric
          </li>
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span> scalable-by-design
          </li>
        </ul>
      </div>

      <div class="mb-12" id="modulos">
        <h2 class="font-h2 mb-8 text-3xl font-bold text-white">
          Arquitectura Modular (15 Core Areas)
        </h2>

        <div class="space-y-4">
          {
            modules.map((m) => (
              <div class="glass-panel flex items-start gap-6 rounded-xl border border-white/10 p-6 transition-colors hover:border-emerald-500/30">
                <div class="mt-1 font-mono text-2xl font-bold text-emerald-500/30">
                  {m.id}
                </div>
                <div>
                  <h3 class="mb-1 text-lg font-bold text-white">{m.name}</h3>
                  <p class="text-sm text-white/60">{m.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </main>

    <!-- Right TOC (Optional, can be added later) -->
    <div class="hidden w-48 flex-shrink-0 lg:block"></div>
  </div>

  <Footer />
</Layout>
