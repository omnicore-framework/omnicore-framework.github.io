---

---

<footer
  class="px-margin relative w-full overflow-hidden border-t border-white/5 bg-black/90 py-16"
>
  <!-- Subtle glow at the bottom -->
  <div
    class="pointer-events-none absolute bottom-0 left-1/2 h-32 w-3/4 -translate-x-1/2 bg-emerald-500/5 blur-[100px]"
  >
  </div>

  <div
    class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 gap-12 md:grid-cols-4"
  >
    <div class="col-span-1 md:col-span-2">
      <a
        href="/"
        class="mb-6 flex w-fit items-center gap-3 transition-opacity hover:opacity-80"
      >
        <img
          src="/Logo.png"
          alt="OmniCore Logo"
          class="h-6 w-auto opacity-90 drop-shadow-[0_0_8px_rgba(68,246,136,0.3)]"
        />
        <div class="font-h3 text-h3 text-primary font-bold tracking-tight">
          OmniCore Framework
        </div>
      </a>
      <p class="mb-6 pr-4 text-sm leading-relaxed text-white/50 lg:pr-12">
        Ecosistema Inteligente de Infraestructura Nativo para IA. La capa
        operativa autónoma para sistemas modernos.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="https://github.com/omnicore-framework"
          target="_blank"
          class="text-white/40 transition-colors hover:text-emerald-400"
        >
          <svg
            class="h-5 w-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="col-span-1 flex flex-col gap-4">
      <h4 class="mb-2 font-semibold text-white">Recursos</h4>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="/docs"
      >
        <span class="material-symbols-outlined text-[16px]">menu_book</span> Documentation
      </a>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="#"
      >
        <span class="material-symbols-outlined text-[16px]">description</span> Whitepaper
      </a>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="#"
      >
        <span class="material-symbols-outlined text-[16px]">api</span> API Reference
      </a>
    </div>

    <div class="col-span-1 flex flex-col gap-4">
      <h4 class="mb-2 font-semibold text-white">Ecosistema</h4>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="#"
      >
        <span class="material-symbols-outlined text-[16px]">monitor_heart</span> Status
      </a>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="#"
      >
        <span class="material-symbols-outlined text-[16px]">shield</span> Security
        Policy
      </a>
      <a
        class="flex w-fit items-center gap-2 text-sm text-white/60 transition-colors hover:text-emerald-400"
        href="#"
      >
        <span class="material-symbols-outlined text-[16px]">gavel</span> Legal
      </a>
    </div>
  </div>

  <div
    class="mx-auto mt-16 flex max-w-7xl flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 md:flex-row"
  >
    <span class="font-mono text-xs text-white/40"
      >© {new Date().getFullYear()} OmniCore Framework. All rights reserved.</span
    >
    <div
      class="flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/5 px-3 py-1.5 font-mono text-[10px] tracking-widest text-emerald-500/80 uppercase"
    >
      <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-500"
      ></span>
      Neural Link Active
    </div>
  </div>
</footer>
