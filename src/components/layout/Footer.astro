---
---
<footer class="bg-black/90 w-full py-16 px-margin border-t border-white/5 relative overflow-hidden">
    <!-- Subtle glow at the bottom -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-emerald-500/5 blur-[100px] pointer-events-none"></div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 max-w-7xl mx-auto relative z-10">
        <div class="col-span-1 md:col-span-2">
            <a href="/" class="flex items-center gap-3 mb-6 hover:opacity-80 transition-opacity w-fit">
                <img src="/Logo.png" alt="OmniCore Logo" class="h-6 w-auto opacity-90 drop-shadow-[0_0_8px_rgba(68,246,136,0.3)]" />
                <div class="font-h3 text-h3 text-primary font-bold tracking-tight">OmniCore Framework</div>
            </a>
            <p class="text-white/50 text-sm leading-relaxed mb-6 pr-4 lg:pr-12">
                Ecosistema Inteligente de Infraestructura Nativo para IA. La capa operativa autónoma para sistemas modernos.
            </p>
            <div class="flex items-center gap-4">
                <a href="https://github.com/omnicore-framework" target="_blank" class="text-white/40 hover:text-emerald-400 transition-colors">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path>
                    </svg>
                </a>
            </div>
        </div>
        
        <div class="col-span-1 flex flex-col gap-4">
            <h4 class="text-white font-semibold mb-2">Recursos</h4>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="/docs">
                <span class="material-symbols-outlined text-[16px]">menu_book</span> Documentation
            </a>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="#">
                <span class="material-symbols-outlined text-[16px]">description</span> Whitepaper
            </a>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="#">
                <span class="material-symbols-outlined text-[16px]">api</span> API Reference
            </a>
        </div>

        <div class="col-span-1 flex flex-col gap-4">
            <h4 class="text-white font-semibold mb-2">Ecosistema</h4>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="#">
                <span class="material-symbols-outlined text-[16px]">monitor_heart</span> Status
            </a>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="#">
                <span class="material-symbols-outlined text-[16px]">shield</span> Security Policy
            </a>
            <a class="text-white/60 hover:text-emerald-400 transition-colors text-sm flex items-center gap-2 w-fit" href="#">
                <span class="material-symbols-outlined text-[16px]">gavel</span> Legal
            </a>
        </div>
    </div>
    
    <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
        <span class="font-mono text-white/40 text-xs">© {new Date().getFullYear()} OmniCore Framework. All rights reserved.</span>
        <div class="flex items-center gap-2 text-emerald-500/80 font-mono text-[10px] uppercase tracking-widest bg-emerald-500/5 px-3 py-1.5 rounded-full border border-emerald-500/20">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Neural Link Active
        </div>
    </div>
</footer>
