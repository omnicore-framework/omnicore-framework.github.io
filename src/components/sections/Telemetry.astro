---
---
<section class="py-24 px-margin max-w-7xl mx-auto" id="telemetry">
    <div class="mb-12 text-center">
        <span class="text-secondary font-mono text-xs tracking-widest uppercase">[[TEL]] Live Telemetry</span>
        <h2 class="font-h2 text-h2 text-on-surface mt-2">Neural Link Status</h2>
        <p class="font-body-md text-body-md text-white max-w-2xl mx-auto">Holographic infrastructure observability with live AI agent tracking and cyber-threat detection.</p>
    </div>
    <div class="glass-panel rounded-xl p-6 relative overflow-hidden h-auto md:h-[600px] flex flex-col md:flex-row gap-6">
        <!-- Left Panel: Metrics -->
        <div class="w-full md:w-1/3 flex flex-col gap-4">
            <div class="bg-surface-container/50 border border-outline-variant/30 rounded-lg p-4">
                <div class="font-mono-label text-mono-label text-primary mb-2 flex justify-between"><span>[[CORE]] NEURAL_LOAD</span><span class="material-symbols-outlined text-sm">memory</span></div>
                <div class="font-h2 text-h2 text-on-surface">42.8%</div>
                <div class="h-2 bg-surface-variant rounded-full mt-2 overflow-hidden">
                    <div class="h-full bg-primary w-[42.8%] shadow-[0_0_10px_#05D96F] animate-pulse"></div>
                </div>
            </div>
            <div class="bg-surface-container/50 border border-outline-variant/30 rounded-lg p-4">
                <div class="font-mono-label text-mono-label text-secondary mb-2 flex justify-between"><span>[[NET]] SYNC_TRAFFIC</span><span class="material-symbols-outlined text-sm">router</span></div>
                <div class="font-h2 text-h2 text-on-surface">1.2 TB/s</div>
                <div class="mt-2 text-xs text-white">Active Nodes: 12,049 | Latency: 0.2ms</div>
            </div>
            <div class="bg-surface-container/50 border border-outline-variant/30 rounded-lg p-4 flex-grow">
                <div class="font-mono-label text-mono-label text-error mb-2 flex justify-between"><span>[[SEC]] THREAT_LEVEL</span><span class="material-symbols-outlined text-sm">security</span></div>
                <div class="font-h3 text-h3 text-error uppercase tracking-widest">Nominal</div>
                <ul class="mt-4 space-y-2 text-sm font-mono text-white">
                    <li class="flex justify-between border-b border-outline-variant/20 pb-1"><span>Auth Bypass</span><span class="text-primary">[BLOCKED]</span></li>
                    <li class="flex justify-between border-b border-outline-variant/20 pb-1"><span>DDoS Volumetric</span><span class="text-primary">[MITIGATED]</span></li>
                    <li class="flex justify-between border-b border-outline-variant/20 pb-1"><span>Neural Poisoning</span><span class="text-primary">[QUARANTINED]</span></li>
                    <li class="flex justify-between border-b border-outline-variant/20 pb-1"><span>Kernel Injection</span><span class="text-primary">[IMMUNIZED]</span></li>
                </ul>
            </div>
        </div>
        <!-- Right Panel: Map/Visual -->
        <div class="w-full md:w-2/3 bg-surface-container/30 border border-outline-variant/30 rounded-lg relative overflow-hidden">
            <img alt="Global Threat Map" class="w-full h-full object-cover opacity-40 mix-blend-luminosity filter sepia hue-rotate-[110deg] saturate-200" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDzu545myEMAiHUtMTMXVUYp4ai2q8fxp0i5hGN-0-xPTUnJBoZ8Ca_VF8cE3ftr2eND78NE2996ldPr7ecIp0DyP0v9kd4a6yazb3g36hDaR_LtpBdtHmOsJ2LqzeBytsQzphjiWFpzfAiZhApk95Dkl5vim1wYpMREluYHOp4znFyTtNwUl6R1RSGoxrxawLxbRP-vUu0aP2akveP-wEQVW90xAnltBO1C4uce84awNU66pntSVxRumgJ_b6v_RlzIjUd1UdLAs"/>
            <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent"></div>
            <div class="absolute bottom-4 left-4 right-4 flex justify-between items-end">
                <div class="font-mono-label text-mono-label text-primary bg-surface/80 px-2 py-1 rounded backdrop-blur border border-primary/20">LIVE MAP - NEURAL NET ACTIVE</div>
                <div class="flex gap-2">
                    <div class="w-3 h-3 rounded-full bg-primary animate-pulse shadow-[0_0_8px_#05D96F]"></div>
                    <div class="w-3 h-3 rounded-full bg-secondary opacity-50"></div>
                    <div class="w-3 h-3 rounded-full bg-tertiary-container opacity-50"></div>
                </div>
            </div>
        </div>
    </div>
</section>
