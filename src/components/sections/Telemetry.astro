---

---

<section class="px-margin mx-auto max-w-7xl py-24" id="telemetry">
  <div class="mb-12 text-center">
    <span class="text-secondary font-mono text-xs tracking-widest uppercase"
      >[[TEL]] Live Telemetry</span
    >
    <h2 class="font-h2 text-h2 text-on-surface mt-2">Neural Link Status</h2>
    <p class="font-body-md text-body-md mx-auto max-w-2xl text-white">
      Holographic infrastructure observability with live AI agent tracking and
      cyber-threat detection.
    </p>
  </div>
  <div
    class="glass-panel relative flex h-auto flex-col gap-6 overflow-hidden rounded-xl p-6 md:h-[600px] md:flex-row"
  >
    <!-- Left Panel: Metrics -->
    <div class="flex w-full flex-col gap-4 md:w-1/3">
      <div
        class="bg-surface-container/50 border-outline-variant/30 rounded-lg border p-4"
      >
        <div
          class="font-mono-label text-mono-label text-primary mb-2 flex justify-between"
        >
          <span>[[CORE]] NEURAL_LOAD</span><span
            class="material-symbols-outlined text-sm">memory</span>
        </div>
        <div class="font-h2 text-h2 text-on-surface">42.8%</div>
        <div class="bg-surface-variant mt-2 h-2 overflow-hidden rounded-full">
          <div
            class="bg-primary h-full w-[42.8%] animate-pulse shadow-[0_0_10px_#05D96F]"
          >
          </div>
        </div>
      </div>
      <div
        class="bg-surface-container/50 border-outline-variant/30 rounded-lg border p-4"
      >
        <div
          class="font-mono-label text-mono-label text-secondary mb-2 flex justify-between"
        >
          <span>[[NET]] SYNC_TRAFFIC</span><span
            class="material-symbols-outlined text-sm">router</span>
        </div>
        <div class="font-h2 text-h2 text-on-surface">1.2 TB/s</div>
        <div class="mt-2 text-xs text-white">
          Active Nodes: 12,049 | Latency: 0.2ms
        </div>
      </div>
      <div
        class="bg-surface-container/50 border-outline-variant/30 flex-grow rounded-lg border p-4"
      >
        <div
          class="font-mono-label text-mono-label text-error mb-2 flex justify-between"
        >
          <span>[[SEC]] THREAT_LEVEL</span><span
            class="material-symbols-outlined text-sm">security</span>
        </div>
        <div class="font-h3 text-h3 text-error tracking-widest uppercase">
          Nominal
        </div>
        <ul class="mt-4 space-y-2 font-mono text-sm text-white">
          <li
            class="border-outline-variant/20 flex justify-between border-b pb-1"
          >
            <span>Auth Bypass</span><span class="text-primary">[BLOCKED]</span>
          </li>
          <li
            class="border-outline-variant/20 flex justify-between border-b pb-1"
          >
            <span>DDoS Volumetric</span><span class="text-primary"
              >[MITIGATED]</span>
          </li>
          <li
            class="border-outline-variant/20 flex justify-between border-b pb-1"
          >
            <span>Neural Poisoning</span><span class="text-primary"
              >[QUARANTINED]</span>
          </li>
          <li
            class="border-outline-variant/20 flex justify-between border-b pb-1"
          >
            <span>Kernel Injection</span><span class="text-primary"
              >[IMMUNIZED]</span>
          </li>
        </ul>
      </div>
    </div>
    <!-- Right Panel: Map/Visual -->
    <div
      class="bg-surface-container/30 border-outline-variant/30 relative w-full overflow-hidden rounded-lg border md:w-2/3"
    >
      <img
        alt="Global Threat Map"
        class="h-full w-full object-cover opacity-40 mix-blend-luminosity hue-rotate-[110deg] saturate-200 sepia filter"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuCDzu545myEMAiHUtMTMXVUYp4ai2q8fxp0i5hGN-0-xPTUnJBoZ8Ca_VF8cE3ftr2eND78NE2996ldPr7ecIp0DyP0v9kd4a6yazb3g36hDaR_LtpBdtHmOsJ2LqzeBytsQzphjiWFpzfAiZhApk95Dkl5vim1wYpMREluYHOp4znFyTtNwUl6R1RSGoxrxawLxbRP-vUu0aP2akveP-wEQVW90xAnltBO1C4uce84awNU66pntSVxRumgJ_b6v_RlzIjUd1UdLAs"
      />
      <div
        class="from-surface absolute inset-0 bg-gradient-to-t to-transparent"
      >
      </div>
      <div
        class="absolute right-4 bottom-4 left-4 flex items-end justify-between"
      >
        <div
          class="font-mono-label text-mono-label text-primary bg-surface/80 border-primary/20 rounded border px-2 py-1 backdrop-blur"
        >
          LIVE MAP - NEURAL NET ACTIVE
        </div>
        <div class="flex gap-2">
          <div
            class="bg-primary h-3 w-3 animate-pulse rounded-full shadow-[0_0_8px_#05D96F]"
          >
          </div>
          <div class="bg-secondary h-3 w-3 rounded-full opacity-50"></div>
          <div class="bg-tertiary-container h-3 w-3 rounded-full opacity-50">
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
