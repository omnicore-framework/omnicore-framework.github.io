---

---

<section class="relative overflow-hidden py-24" id="core-integration">
  <!-- Background visual elements removed per user request -->

  <div class="px-margin relative z-10 mx-auto w-full max-w-7xl">
    <div
      class="grid w-full grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16"
    >
      <!-- Left Column: Text Content -->
      <div class="flex w-full min-w-0 flex-col">
        <div
          class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1"
        >
          <span class="h-2 w-2 animate-pulse rounded-full bg-emerald-500"
          ></span>
          <span
            class="font-mono text-[10px] tracking-widest text-emerald-400 uppercase"
            >Integration Layer</span
          >
        </div>

        <h2 class="font-h2 text-h2 text-on-surface mb-6 w-full leading-tight">
          OmniCore Core: El Estándar de <span class="text-emerald-400"
            >Interoperabilidad</span
          >
        </h2>

        <p
          class="font-body-md mb-8 w-full pr-0 leading-relaxed text-white/70 lg:pr-8"
        >
          Aunque cada organización evoluciona como un dominio independiente, <strong
            >OmniCore Core</strong
          > actúa como el cerebro central. Impone un estándar unificado de arquitectura,
          documentación y flujo de datos.
        </p>

        <ul class="mb-10 w-full space-y-4">
          {
            [
              {
                title: 'Runtime Engine',
                desc: 'Motor principal que coordina la ejecución de todos los módulos.',
              },
              {
                title: 'Event & Plugin System',
                desc: 'Arquitectura extensible para comunicación interna y expansión dinámica.',
              },
              {
                title: 'Lifecycle & Config',
                desc: 'Gestión centralizada del ciclo de vida y configuraciones globales.',
              },
            ].map((item) => (
              <li class="flex gap-4">
                <div class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-emerald-500/30">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400" />
                </div>
                <div>
                  <h4 class="text-on-surface text-sm font-semibold">
                    {item.title}
                  </h4>
                  <p class="text-sm text-white/50">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ul>

        <div class="flex w-full flex-wrap gap-4">
          <button
            class="rounded-lg bg-emerald-500 px-6 py-3 font-semibold text-black transition-all duration-300 hover:bg-emerald-400"
          >
            Explore Core Docs
          </button>
          <button
            class="rounded-lg border border-white/10 bg-white/5 px-6 py-3 font-semibold text-white transition-all duration-300 hover:bg-white/10"
          >
            View Architecture
          </button>
        </div>
      </div>

      <!-- Right Column: Code Visual -->
      <div class="mt-12 flex w-full min-w-0 lg:mt-0 lg:justify-end">
        <div
          class="glass-panel relative w-full max-w-[600px] overflow-hidden rounded-2xl border border-white/10 p-6 shadow-2xl"
        >
          <div
            class="mb-6 flex items-center gap-2 border-b border-white/5 pb-4"
          >
            <div class="h-3 w-3 rounded-full bg-emerald-500/50"></div>
            <div class="h-3 w-3 rounded-full bg-emerald-500/30"></div>
            <div class="h-3 w-3 rounded-full bg-emerald-500/10"></div>
            <div class="ml-2 font-mono text-xs text-white/40">
              omnicore.config.ts
            </div>
          </div>

          <div class="w-full overflow-x-auto">
            <pre
              class="inline-block w-full min-w-max pr-6 font-mono text-sm leading-relaxed text-emerald-400/80">
<code><span class="text-white/40">import</span> &#123; CoreFramework &#125; <span class="text-white/40">from</span> '@omnicore/core';
<span class="text-white/40">import</span> &#123; AIEngine &#125; <span class="text-white/40">from</span> '@omnicore/ai';
<span class="text-white/40">import</span> &#123; ZeroTrust &#125; <span class="text-white/40">from</span> '@omnicore/security';

<span class="text-white/40">// Inicialización de Arquitectura Unificada</span>
<span class="text-white/40">const</span> nexus = <span class="text-white/40">new</span> CoreFramework(&#123;
  modules: [AIEngine, ZeroTrust],
  telemetry: <span class="text-white/40">true</span>,
  syncProtocol: <span class="text-emerald-300">'realtime-mesh'</span>
&#125;);

<span class="text-white/40">await</span> nexus.<span class="text-white">ignite</span>();
<span class="text-white/50">// &gt; [OK] Core Framework Active</span>
<span class="text-white/50">// &gt; [OK] Interoperability Layer Online</span></code>
                        </pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
