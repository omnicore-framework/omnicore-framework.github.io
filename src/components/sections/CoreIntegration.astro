---
---
<section class="py-24 relative overflow-hidden" id="core-integration">
    <!-- Background visual elements removed per user request -->

    <div class="px-margin max-w-7xl mx-auto relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">
            <!-- Left Column: Text Content -->
            <div class="flex flex-col w-full min-w-0">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 mb-6 w-fit">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                    <span class="text-[10px] font-mono text-emerald-400 uppercase tracking-widest">Integration Layer</span>
                </div>
                
                <h2 class="font-h2 text-h2 text-on-surface mb-6 leading-tight w-full">
                    OmniCore Core: El Estándar de <span class="text-emerald-400">Interoperabilidad</span>
                </h2>
                
                <p class="font-body-md text-white/70 mb-8 w-full leading-relaxed pr-0 lg:pr-8">
                    Aunque cada organización evoluciona como un dominio independiente, <strong>OmniCore Core</strong> actúa como el cerebro central. Impone un estándar unificado de arquitectura, documentación y flujo de datos.
                </p>

                <ul class="space-y-4 mb-10 w-full">
                    {[
                        { title: 'Runtime Engine', desc: 'Motor principal que coordina la ejecución de todos los módulos.' },
                        { title: 'Event & Plugin System', desc: 'Arquitectura extensible para comunicación interna y expansión dinámica.' },
                        { title: 'Lifecycle & Config', desc: 'Gestión centralizada del ciclo de vida y configuraciones globales.' }
                    ].map(item => (
                        <li class="flex gap-4">
                            <div class="mt-1 flex-shrink-0 w-5 h-5 rounded-full border border-emerald-500/30 flex items-center justify-center">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                            </div>
                            <div>
                                <h4 class="text-on-surface font-semibold text-sm">{item.title}</h4>
                                <p class="text-white/50 text-sm">{item.desc}</p>
                            </div>
                        </li>
                    ))}
                </ul>

                <div class="flex flex-wrap gap-4 w-full">
                    <button class="px-6 py-3 rounded-lg bg-emerald-500 text-black font-semibold hover:bg-emerald-400 transition-all duration-300">
                        Explore Core Docs
                    </button>
                    <button class="px-6 py-3 rounded-lg bg-white/5 border border-white/10 text-white font-semibold hover:bg-white/10 transition-all duration-300">
                        View Architecture
                    </button>
                </div>
            </div>

            <!-- Right Column: Code Visual -->
            <div class="w-full min-w-0 flex lg:justify-end mt-12 lg:mt-0">
                <div class="glass-panel rounded-2xl p-6 border border-white/10 w-full max-w-[600px] overflow-hidden shadow-2xl relative">
                    
                    <div class="flex items-center gap-2 mb-6 border-b border-white/5 pb-4">
                        <div class="w-3 h-3 rounded-full bg-emerald-500/50"></div>
                        <div class="w-3 h-3 rounded-full bg-emerald-500/30"></div>
                        <div class="w-3 h-3 rounded-full bg-emerald-500/10"></div>
                        <div class="ml-2 font-mono text-xs text-white/40">omnicore.config.ts</div>
                    </div>
                    
                    <div class="overflow-x-auto w-full">
                        <pre class="font-mono text-sm leading-relaxed text-emerald-400/80 w-full inline-block min-w-max pr-6">
<code><span class="text-white/40">import</span> &#123; CoreFramework &#125; <span class="text-white/40">from</span> '@omnicore/core';
<span class="text-white/40">import</span> &#123; AIEngine &#125; <span class="text-white/40">from</span> '@omnicore/ai';
<span class="text-white/40">import</span> &#123; ZeroTrust &#125; <span class="text-white/40">from</span> '@omnicore/security';

<span class="text-white/40">// Inicialización de Arquitectura Unificada</span>
<span class="text-white/40">const</span> nexus = <span class="text-white/40">new</span> CoreFramework(&#123;
  modules: [AIEngine, ZeroTrust],
  telemetry: <span class="text-white/40">true</span>,
  syncProtocol: <span class="text-emerald-300">'realtime-mesh'</span>
&#125;);

<span class="text-white/40">await</span> nexus.<span class="text-white">ignite</span>();
<span class="text-white/50">// > [OK] Core Framework Active</span>
<span class="text-white/50">// > [OK] Interoperability Layer Online</span></code>
                        </pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
