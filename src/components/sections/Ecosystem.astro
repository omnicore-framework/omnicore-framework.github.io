---

<section class="px-margin mx-auto max-w-7xl py-24" id="ecosystem">
  <div class="mb-16 text-center">
    <h2 class="font-h2 text-h2 text-on-surface mb-4">Ecosistema Modular</h2>
    <p class="font-body-md text-body-md mx-auto max-w-2xl text-white/70">
      Quince áreas especializadas diseñadas para funcionar de forma autónoma y
      cooperar como un sistema unificado.
    </p>
  </div>
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      organizations.map((org) => (
        <div class="glass-panel group relative flex flex-col overflow-hidden rounded-2xl border border-white/5 p-6 transition-all duration-500 hover:border-emerald-500/30">
          <div
            class={`absolute top-0 right-0 h-24 w-24 bg-${org.color}/5 -mt-4 -mr-4 rounded-bl-full transition-all duration-700 group-hover:scale-150 group-hover:opacity-20`}
          />

          <div class="relative z-10 flex h-full flex-col">
            <div class="mb-4 flex items-center gap-3">
              <div
                class={`rounded-lg p-2 bg-${org.color}/10 border border-${org.color}/20 flex-shrink-0`}
              >
                <span
                  class={`material-symbols-outlined text-${org.color} text-2xl group-hover:drop-shadow-[0_0_8px_rgba(68,246,136,0.6)]`}
                >
                  {org.icon}
                </span>
              </div>
              <h3 class="font-h3 text-on-surface text-lg leading-tight">
                {org.title}
              </h3>
            </div>

            <p class="font-body-md mb-6 flex-grow text-sm text-white/50">
              {org.desc}
            </p>

            <div class="mt-auto flex flex-wrap gap-1.5">
              {org.nodes.map((node) => (
                <span class="rounded border border-white/10 bg-white/5 px-2.5 py-1 font-mono text-[11px] tracking-wider text-emerald-400/70 uppercase">
                  {node}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
