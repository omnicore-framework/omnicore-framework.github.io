---
import ThreeDObject from '../visuals/ThreeDObject.astro';
---

<header class="relative flex min-h-screen items-center overflow-hidden">
  <!-- Main Container -->
  <div
    class="px-margin relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center gap-12 lg:flex-row lg:gap-16"
  >
    <!-- Left Side: Content -->
    <div
      class="flex w-full flex-col items-start pt-20 text-left lg:w-1/2 lg:pt-0"
    >
      <!-- Badges -->
      <div
        class="relative mb-6 flex flex-col space-y-4 border-l border-white/5 pl-6"
      >
        <!-- Top Bracket Decor -->
        <div
          class="border-primary/40 absolute -top-2 -left-2 h-4 w-4 border-t-2 border-l-2"
        >
        </div>

        <div
          class="flex w-fit items-center space-x-3 rounded-sm border border-white/10 bg-[#0a0a0a] px-4 py-2"
        >
          <span class="bg-primary h-2 w-2 rounded-full shadow-[0_0_8px_#44f688]"
          ></span>
          <span
            class="font-mono text-[11px] tracking-[0.2em] text-white/80 uppercase"
            >MISSION STATUS | LATEST RELEASE V2.4.0</span
          >
        </div>
        <div
          class="flex w-fit items-center space-x-3 rounded-sm border border-yellow-500/20 bg-yellow-500/5 px-4 py-2"
        >
          <span class="material-symbols-outlined text-sm text-yellow-500/80"
            >warning</span
          >
          <span
            class="font-mono text-[11px] tracking-[0.2em] text-yellow-500/80 uppercase"
            >// CAUTION: NEURAL LINK ACTIVE — SECURE LINE</span
          >
        </div>

        <!-- Bottom Bracket Decor (End of badges) -->
        <div
          class="absolute right-0 bottom-0 h-4 w-4 border-r-2 border-b-2 border-white/10 opacity-0 lg:opacity-100"
        >
        </div>
      </div>

      <!-- Main Heading -->
      <div class="relative mb-10 w-full">
        <h1
          class="font-h1 mb-6 text-[clamp(2.5rem,6vw,5rem)] leading-[0.85] font-bold tracking-[-0.04em] text-white uppercase"
        >
          OMNICORE <br />
          <span
            class="from-primary via-secondary to-primary/40 bg-gradient-to-r bg-clip-text text-transparent"
            >FRAMEWORK</span
          >
        </h1>

        <p
          class="font-body-lg max-w-[540px] text-base leading-relaxed font-light text-white/80 md:text-lg"
        >
          <strong
            >Ecosistema Inteligente de Infraestructura Nativo para IA.</strong
          ><br />
          La Capa Operativa para Sistemas Inteligentes capaz de comprender, automatizar,
          proteger y evolucionar infraestructuras completas de forma autónoma.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="mb-8 flex flex-wrap gap-6">
        <a
          href="/docs"
          class="border-primary/40 text-primary group hover:bg-primary flex items-center rounded-sm border bg-[#002B16] px-10 py-5 font-mono text-[11px] tracking-[0.2em] uppercase transition-all hover:text-black hover:shadow-[0_0_40px_rgba(68,246,136,0.2)] active:scale-95"
        >
          <span
            class="material-symbols-outlined mr-3 text-base transition-transform group-hover:rotate-12"
            >rocket_launch</span
          >
          GET STARTED
          <span class="material-symbols-outlined ml-3 text-base"
            >arrow_forward</span
          >
        </a>
        <a
          href="https://github.com/omnicore-framework"
          target="_blank"
          class="flex items-center rounded-sm border border-white/10 px-10 py-5 font-mono text-[11px] tracking-[0.2em] text-white/50 uppercase transition-all hover:bg-white/5 active:scale-95"
        >
          <span class="material-symbols-outlined mr-3 text-base">code</span>
          SOURCE CODE
        </a>
      </div>

      <!-- CLI Block -->
      <div class="relative w-full max-w-[400px]">
        <!-- Bracket Decor -->
        <div
          class="absolute -top-2 -left-2 h-4 w-4 border-t-2 border-l-2 border-white/20"
        >
        </div>

        <div
          class="flex items-center justify-between rounded-sm border border-white/10 bg-black/80 px-6 py-4 font-mono text-sm shadow-2xl backdrop-blur-md"
        >
          <div class="flex items-center space-x-4">
            <span
              class="text-primary/40 border-r border-white/10 pr-4 text-[11px] tracking-wider uppercase"
              >CMDR&gt;</span
            >
            <span class="text-white/90">omnicore install --core</span>
          </div>
          <button
            class="material-symbols-outlined hover:text-primary cursor-pointer text-base text-white/30 transition-colors"
            >content_copy</button
          >
        </div>
        <!-- Bottom Corner Decoration -->
        <div
          class="border-primary/50 absolute -right-2 -bottom-2 h-4 w-4 border-r-2 border-b-2"
        >
        </div>
      </div>
    </div>

    <!-- Right Side: 3D Object (Independent container) -->
    <div
      class="relative flex h-[400px] w-full items-center justify-center lg:h-[700px] lg:w-1/2"
    >
      <!-- Glow background -->
      <div
        class="bg-primary/5 pointer-events-none absolute inset-0 rounded-full blur-[140px]"
      >
      </div>
      <div class="relative z-20 h-full w-full">
        <ThreeDObject />
      </div>
    </div>
  </div>
</header>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-20px) rotate(2deg);
    }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
