---
import ThreeDObject from '../visuals/ThreeDObject.astro';
---
<header class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Main Container -->
    <div class="relative z-10 w-full max-w-[1440px] mx-auto px-8 md:px-16 flex flex-col lg:flex-row items-center justify-between gap-12">
        
        <!-- Left Side: Content (Fixed width for stability) -->
        <div class="w-full lg:w-[60%] flex flex-col items-start text-left pt-20 lg:pt-0">
            
            <!-- Badges -->
            <div class="relative flex flex-col space-y-4 mb-12 pl-6 border-l border-white/5">
                <!-- Top Bracket Decor -->
                <div class="absolute -top-2 -left-2 w-4 h-4 border-t-2 border-l-2 border-primary/40"></div>
                
                <div class="flex items-center space-x-3 bg-[#0a0a0a] border border-white/10 rounded-sm px-4 py-2 w-fit">
                    <span class="w-2 h-2 rounded-full bg-primary shadow-[0_0_8px_#44f688]"></span>
                    <span class="font-mono text-[11px] tracking-[0.2em] text-white/80 uppercase">MISSION STATUS | LATEST RELEASE V2.4.0</span>
                </div>
                <div class="flex items-center space-x-3 bg-yellow-500/5 border border-yellow-500/20 rounded-sm px-4 py-2 w-fit">
                    <span class="material-symbols-outlined text-sm text-yellow-500/80">warning</span>
                    <span class="font-mono text-[11px] tracking-[0.2em] text-yellow-500/80 uppercase">// CAUTION: NEURAL LINK ACTIVE — SECURE LINE</span>
                </div>
                
                <!-- Bottom Bracket Decor (End of badges) -->
                <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-white/10 opacity-0 lg:opacity-100"></div>
            </div>

            <!-- Main Heading -->
            <div class="mb-10 w-full relative">
                <h1 class="font-h1 text-[clamp(2.5rem,8vw,6rem)] text-white leading-[0.85] tracking-[-0.04em] uppercase font-bold">
                    BUILD WITHOUT <br/>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-secondary to-primary/40">BOUNDARIES</span>
                </h1>
            </div>

            <!-- Description -->
            <div class="max-w-[540px] mb-12">
                <p class="font-body-lg text-base md:text-lg text-white leading-relaxed font-light">
                    The async infrastructure framework with a <span class="text-primary font-medium">neural-powered core</span> 
                    that delivers <span class="text-secondary font-medium">10x faster</span> responses. Elegant architecture, 
                    maximum productivity, zero compromise.
                </p>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-wrap gap-6 mb-16">
                <button class="bg-[#002B16] border border-primary/40 text-primary px-10 py-5 rounded-sm font-mono text-[11px] tracking-[0.2em] uppercase flex items-center group transition-all hover:bg-primary hover:text-black hover:shadow-[0_0_40px_rgba(68,246,136,0.2)] active:scale-95">
                    <span class="material-symbols-outlined mr-3 text-base group-hover:rotate-45 transition-transform">bolt</span>
                    INITIALIZE MISSION
                    <span class="material-symbols-outlined ml-3 text-base">arrow_forward</span>
                </button>
                <button class="border border-white/10 text-white/50 px-10 py-5 rounded-sm font-mono text-[11px] tracking-[0.2em] uppercase flex items-center hover:bg-white/5 transition-all active:scale-95">
                    <span class="material-symbols-outlined mr-3 text-base">code</span>
                    SOURCE CODE
                </button>
            </div>

            <!-- CLI Block -->
            <div class="relative w-full max-w-[400px]">
                <!-- Bracket Decor -->
                <div class="absolute -top-2 -left-2 w-4 h-4 border-t-2 border-l-2 border-white/20"></div>
                
                <div class="bg-black/80 border border-white/10 rounded-sm px-6 py-4 flex items-center justify-between font-mono text-sm shadow-2xl backdrop-blur-md">
                    <div class="flex items-center space-x-4">
                        <span class="text-primary/40 uppercase text-[10px] border-r border-white/10 pr-4 tracking-tighter">CMDR&gt;</span>
                        <span class="text-white/90">npm i @omnicore/framework</span>
                    </div>
                    <button class="material-symbols-outlined text-white/30 hover:text-primary cursor-pointer text-base transition-colors">content_copy</button>
                </div>
                <!-- Bottom Corner Decoration -->
                <div class="absolute -bottom-2 -right-2 w-4 h-4 border-r-2 border-b-2 border-primary/50"></div>
            </div>
        </div>

        <!-- Right Side: 3D Object (Independent container) -->
        <div class="w-full lg:w-[40%] h-[400px] lg:h-[700px] flex items-center justify-center relative">
            <!-- Glow background -->
            <div class="absolute inset-0 bg-primary/5 rounded-full blur-[140px] pointer-events-none"></div>
            <div class="w-full h-full relative z-20">
                <ThreeDObject />
            </div>
        </div>

    </div>
</header>




<style>
    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(2deg); }
    }
    .animate-float {
        animation: float 6s ease-in-out infinite;
    }
</style>
